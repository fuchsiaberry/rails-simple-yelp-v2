<h1><%= @restaurant.name %></h1>

<p>Cuisine: <%= @restaurant.category %></p>

<div>
  <h3>Reviews</h3>
  <% @restaurant.reviews.each do |review| %>
    <li>Rating:<%= "⭐️" *  review.rating %> - <%= review.content %>  <%= link_to "🗑️", review_path(review), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}  %></li>
  <% end %>
</div>


<%= link_to "Write a Review", new_restaurant_review_path(@restaurant), class: "btn btn-outline-secondary" %>
<%= link_to "Home", restaurants_path, class: "btn btn-outline-primary" %>
